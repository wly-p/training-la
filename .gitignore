# ── macOS ──
.DS_Store

# ── Xcode ──
DerivedData/
build/
*.xcuserstate
xcuserdata/
*.moved-aside
*.pbxuser
!default.pbxuser
*.perspectivev3
!default.perspectivev3
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# ── Swift Package Manager ──
.build/
.swiftpm/xcode/package.xcworkspace/xcuserdata/
.swiftpm/xcode/xcuserdata/
.swiftpm/configuration/
# Package.resolved 要進版控（鎖第三方版本，讓 build 可重現）

# ── 簽章 / 機密：永不進 repo ──
*.p12
*.cer
*.certSigningRequest
*.mobileprovision
*.provisionprofile
AuthKey_*.p8
Secrets.xcconfig
*.secrets.xcconfig
.env
.env.*
!.env.example

# ── fastlane（日後 CI 用到）──
fastlane/report.xml
fastlane/Preview.html
fastlane/test_output/
fastlane/screenshots/**/*.png

# ── 其他 ──
*.log

# 本機開發筆記（Notion 流程等內部資訊，不進 repo）
*.local.md

# xcodegen 產物（用 xcodegen generate 重生）
TrainingLa.xcodeproj/

# xcodegen 產生的 Info.plist（由 project.yml 定義）
App/Info.plist

# xcode-build-server 產物（指向本機 DerivedData，供 VS Code SourceKit-LSP 用；跟 xcodeproj 一樣不進版控）
buildServer.json
