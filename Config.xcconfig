// 專案層級共用設定：套用到全部 build configuration（連 App 本身的 build 都會讀到，
// 不是只有測試才用），Makefile 與 Xcode 專案共用同一份（單一真實來源）。
// 改這裡就好，不要在 Makefile / project.yml 裡另外寫死。
//
// TEST_DEVICE：跑 UITests 用的模擬器機型名稱（對應 `xcrun simctl list devicetypes`）。
// Makefile 用它組 `xcodebuild -destination`；同時也放進 Xcode 的 Build Settings（User-Defined），
// 讓專案裡讀得到同一個值——但 Xcode GUI 工具列的模擬器下拉選單是互動式狀態，
// 不會被這個值動態帶動，仍要在 Xcode 裡手動選（這是 Xcode 本身的限制）。
TEST_DEVICE = iPhone 17

// TEST_HEADLESS（bool：true/false）：true（預設）＝ 不主動打開 Simulator.app 視覺化視窗；
// false ＝ Makefile 會先 `open -a Simulator` 讓你能看著 UITests 跑。
// 不管哪個值，xcodebuild 都還是會啟動模擬器 process，這個開關只影響「要不要順便開視窗給人看」。
TEST_HEADLESS = true

// 本機簽章設定（gitignored，開源 repo 不放任何人的 Team ID）。
// 實機建置前自己建一份 Signing.secrets.xcconfig，內容一行：
//   DEVELOPMENT_TEAM = <你的 Team ID>
// 沒有這個檔也能過（optional include），只是要在 Xcode GUI 手選 team，
// 且每次 `xcodegen generate` 後得重選；有這個檔就能在重生後存活。
#include? "Signing.secrets.xcconfig"
