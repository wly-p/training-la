    "settings.data.footer" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Erase all exercises, plans, and workout records; the app returns to its initial state. Appearance settings (theme, app icon) are kept. This cannot be undone." } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "清除所有動作、課表與訓練紀錄，App 回到初始狀態。外觀設定（主題、App 圖示）會保留。此動作無法復原。" } }
      }
    },
    "settings.data.header" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Data" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "資料" } }
      }
    },
    "settings.eraseAll.button" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Erase All Data" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "刪除所有資料" } }
      }
    },
    "settings.eraseAll.confirm.message" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "All exercises, plans, and workout records will be permanently deleted and cannot be recovered." } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "所有動作、課表與訓練紀錄將被永久刪除，且無法復原。" } }
      }
    },
    "settings.eraseAll.confirm.title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Erase all data?" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "確定刪除所有資料？" } }
      }
    },
    "settings.eraseFailed.message" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Something went wrong while erasing data. Please try again." } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "刪除資料時發生錯誤，請再試一次。" } }
      }
    },
    "settings.eraseFailed.title" : {
