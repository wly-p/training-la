    "settings.restReminder.background.footer" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "When the app isn't in the foreground, a system notification reminds you; whether it plays sound follows the “Sound” switch above. Turn this off to disable background reminders entirely." } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "App 不在前景時以系統通知提醒；是否有聲音跟隨上方「聲音」開關。關閉後背景將完全不提醒。" } }
      }
    },
    "settings.restReminder.background.header" : {
